    {
      "cell_type": "markdown",
      "source": [
        "1. Ejecutar la siguiente celda. Si pones el mouse sobre la celda, te va a aparecer un botón de play, presiónalo. Lo que hace ese código es descargar las librerías necesarias para descargar la música."
      ],
      "metadata": {
        "id": "gw-XEXupMIgN"
      }
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "B1U6lIJ4JcHx"
      },
      "outputs": [],
      "source": [
        "!pip install yt-dlp\n",
        "!apt-get install ffmpeg"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import yt_dlp\n",
        "import pandas as pd\n",
        "import os\n",
        "\n",
        "\n",
        "def download_audio_from_search(query):\n",
        "    ydl_opts = {\n",
        "        'format': 'bestaudio/best',\n",
        "        'outtmpl': '/content/%(title)s.%(ext)s',\n",
        "        'default_search': 'ytsearch1',  # solo el primer resultado\n",
        "        'quiet': False,\n",
        "        'postprocessors': [{\n",
        "            'key': 'FFmpegExtractAudio',\n",
        "            'preferredcodec': 'mp3',\n",
        "            'preferredquality': '192',\n",
        "        }],\n",
        "    }\n",
        "\n",
        "    with yt_dlp.YoutubeDL(ydl_opts) as ydl:\n",
        "        ydl.download([query])\n",
        "\n",
        "\n",
        "def download_from_dataframe(df, column_name):\n",
        "    for song_name in df[column_name]:\n",
        "        print(f\"Downloading: {song_name}\")\n",
        "        download_audio_from_search(song_name)"
      ],
      "metadata": {
        "id": "UrCCrkk0Jg79"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
