    {
      "cell_type": "markdown",
      "source": [
        "Para descargar desde una lista de reproducción de llutuve, ejecuta la celda y coloca la URL."
      ],
      "metadata": {
        "id": "bbUqH57mdy5q"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def download_playlist_audio(\n",
        "    playlist_url= None,\n",
        "    output_dir=\"/content/playlists\",\n",
        "    playlist_name=\"playlist\"\n",
        "):\n",
        "\n",
        "    if playlist_url is None:\n",
        "      playlist_url = str(input('Ingresa la URL de tu playlist de youtube: '))\n",
        "    playlist_path = os.path.join(output_dir, playlist_name)\n",
        "    os.makedirs(playlist_path, exist_ok=True)\n",
        "\n",
        "    ydl_opts = {\n",
        "        'format': 'bestaudio/best',\n",
        "        'yesplaylist': True,\n",
        "        'outtmpl': f'{playlist_path}/%(playlist_index)s - %(title)s.%(ext)s',\n",
        "        'quiet': False,\n",
        "        'postprocessors': [{\n",
        "            'key': 'FFmpegExtractAudio',\n",
        "            'preferredcodec': 'mp3',\n",
        "            'preferredquality': '192',\n",
        "        }],\n",
        "    }\n",
        "\n",
        "    with yt_dlp.YoutubeDL(ydl_opts) as ydl:\n",
        "        ydl.download([playlist_url])\n",
        "\n",
        "\n",
        "download_playlist_audio(\n",
        "    #playlist_url=playlist_url,\n",
        "    playlist_name=\"musica_creative_commons\"\n",
        ")"
      ],
      "metadata": {
        "id": "MqpylYynXul1"
      },
